#!/bin/sh

echo "Running pre-commit checks..."

# Frontend lint
echo "→ Frontend: ESLint"
cd frontend && npm run lint
FRONTEND_RESULT=$?
cd ..

# Backend type check
echo "→ Backend: TypeScript check"
cd backend && npx tsc --noEmit
BACKEND_RESULT=$?
cd ..

# Fail if either check failed
if [ $FRONTEND_RESULT -ne 0 ] || [ $BACKEND_RESULT -ne 0 ]; then
  echo "✗ Pre-commit checks failed. Fix the errors above before committing."
  exit 1
fi

echo "✓ Pre-commit checks passed."
