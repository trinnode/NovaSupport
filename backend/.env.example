PORT=4001
NODE_ENV=development

# JWT Secret - REQUIRED for authentication (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-secure-random-secret-here-replace-this

# Local Docker PostgreSQL (for development)
DATABASE_URL=postgresql://novasupport:novasupport@localhost:5432/novasupport
DIRECT_URL=postgresql://novasupport:novasupport@localhost:5432/novasupport

# Supabase (production/staging) - uncomment if using Supabase instead of Docker
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-PROJECT-REF].supabase.co:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-SUPABASE-PROJECT-REF].supabase.co
ALLOWED_ORIGINS=http://localhost:3000,https://nova-support.vercel.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_AVATAR_BUCKET=avatars

# SMTP Email Configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NovaSupport <noreply@novasupport.xyz>
HORIZON_URL=https://horizon-testnet.stellar.org
